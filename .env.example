# Velvet Elves marketing site — environment variables (Vite reads VITE_* at build time).
# Copy to .env.local and fill in. NEVER commit .env.local.

# The real app sign-up lives here. Marketing "Create an account" / "Sign in" route through it.
# Prod: https://app.velvetelves.com  ·  Staging: https://app.stage.velvetelves.com
VITE_APP_URL=https://app.velvetelves.com

# Marketing-only Supabase project (decoupled from the product DB).
# The anon/publishable key is safe client-side ONLY because RLS on marketing_leads
# is INSERT-only — verify with `npm run verify:rls` before wiring any form.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Service-role key — used ONLY by scripts/verify-rls.mjs to seed a row so the
# anon SELECT-denial proves RLS rather than an empty table. Never expose client-side.
SUPABASE_SERVICE_ROLE_KEY=
